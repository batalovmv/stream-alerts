{
  "name": "memelab-notify",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Automatic stream announcements for Telegram and MAX",
  "scripts": {
    "ai": "node scripts/ai.js",
    "ai:task:new": "node scripts/ai.js task:new",
    "ai:handoff:new": "node scripts/ai.js handoff:new",
    "ai:adr:new": "node scripts/ai.js adr:new",
    "ai:check": "node scripts/ai.js check",
    "dev": "concurrently \"pnpm dev:backend\" \"pnpm dev:frontend\"",
    "dev:backend": "pnpm --filter @memelab-notify/backend dev",
    "dev:frontend": "pnpm --filter @memelab-notify/frontend dev",
    "build": "pnpm --filter @memelab-notify/backend build && pnpm --filter @memelab-notify/frontend build",
    "build:backend": "pnpm --filter @memelab-notify/backend build",
    "build:frontend": "pnpm --filter @memelab-notify/frontend build",
    "test": "pnpm --filter @memelab-notify/backend test && pnpm --filter @memelab-notify/frontend test",
    "lint": "eslint apps/",
    "lint:fix": "eslint apps/ --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"apps/**/*.{ts,tsx}\"",
    "prepare": "husky",
    "postinstall": "cd apps/backend && npx prisma generate"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "esbuild",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^20.4.3",
    "@commitlint/config-conventional": "^20.4.3",
    "@typescript-eslint/eslint-plugin": "^8.56.1",
    "@typescript-eslint/parser": "^8.56.1",
    "concurrently": "^9.1.2",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  }
}
